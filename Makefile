	@$(QMAKE) -o Makefile e-commerce.pro

qmake_all: FORCE

e-commerce.app/Contents/PkgInfo: 
	@test -d e-commerce.app/Contents || mkdir -p e-commerce.app/Contents
	@$(DEL_FILE) e-commerce.app/Contents/PkgInfo
	@echo "APPL????" > e-commerce.app/Contents/PkgInfo
e-commerce.app/Contents/Info.plist: 
	@test -d e-commerce.app/Contents || mkdir -p e-commerce.app/Contents
	@$(DEL_FILE) e-commerce.app/Contents/Info.plist
	@plutil -convert xml1 -o - /opt/homebrew/share/qt/mkspecs/macx-clang/Info.plist.app | sed -e "s,@SHORT_VERSION@,1.0,g" -e "s,\$${QMAKE_SHORT_VERSION},1.0,g" -e "s,@FULL_VERSION@,1.0.0,g" -e "s,\$${QMAKE_FULL_VERSION},1.0.0,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" -e "s,@BUNDLEIDENTIFIER@,Adil.e-commerce,g" -e "s,\$${PRODUCT_BUNDLE_IDENTIFIER},Adil.e-commerce,g" -e "s,\$${MACOSX_DEPLOYMENT_TARGET},14.0,g" -e "s,\$${IPHONEOS_DEPLOYMENT_TARGET},,g" -e "s,\$${TVOS_DEPLOYMENT_TARGET},,g" -e "s,\$${WATCHOS_DEPLOYMENT_TARGET},,g" -e "s,\$${IOS_LAUNCH_SCREEN},LaunchScreen,g" -e "s,@ICON@,,g" -e "s,\$${ASSETCATALOG_COMPILER_APPICON_NAME},,g" -e "s,@EXECUTABLE@,e-commerce,g" -e "s,@LIBRARY@,e-commerce,g" -e "s,\$${EXECUTABLE_NAME},e-commerce,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" >e-commerce.app/Contents/Info.plist

all: Makefile \
		e-commerce.app/Contents/PkgInfo \
		e-commerce.app/Contents/Info.plist e-commerce.app/Contents/MacOS/e-commerce

dist: distdir FORCE
	(cd `dirname $(DISTDIR)` && $(TAR) $(DISTNAME).tar $(DISTNAME) && $(COMPRESS) $(DISTNAME).tar) && $(MOVE) `dirname $(DISTDIR)`/$(DISTNAME).tar.gz . && $(DEL_FILE) -r $(DISTDIR)

distdir: FORCE
	@test -d $(DISTDIR) || mkdir -p $(DISTDIR)
	$(COPY_FILE) --parents $(DIST) $(DISTDIR)/
	$(COPY_FILE) --parents resources.qrc $(DISTDIR)/
	$(COPY_FILE) --parents /opt/homebrew/share/qt/mkspecs/features/data/dummy.cpp $(DISTDIR)/
	$(COPY_FILE) --parents Headers/Graphics/Filters.h Headers/Graphics/DialogMessage.h Headers/Graphics/Homepage.h Headers/Graphics/SingleProductCreation.h Headers/Graphics/SingleProductEdit.h Headers/Graphics/Miniature.h Headers/Graphics/ProductsView.h Headers/Graphics/SingleProduct.h Headers/Logic/Clothing.h Headers/Logic/Container.h Headers/Logic/Electronics.h Headers/Logic/FileUtils.h Headers/Logic/PrintedMedia.h Headers/Logic/Product.h Headers/Logic/Visitors/ProductConstVisitorInterface.h Headers/Logic/Visitors/ProductEditorVisitor.h Headers/Logic/Visitors/ProductIconVisitor.h Headers/Logic/Visitors/ProductSingleProductVisitor.h Headers/Logic/Visitors/ProductVisitorInterface.h Headers/Logic/Store.h $(DISTDIR)/
	$(COPY_FILE) --parents Sources/main.cpp Sources/Graphics/Filters.cpp Sources/Graphics/Homepage.cpp Sources/Graphics/SingleProductCreation.cpp Sources/Graphics/SingleProductEdit.cpp Sources/Graphics/Miniature.cpp Sources/Graphics/ProductsView.cpp Sources/Graphics/SingleProduct.cpp Sources/Logic/Clothing.cpp Sources/Logic/Electronics.cpp Sources/Logic/PrintedMedia.cpp Sources/Logic/Product.cpp Sources/Logic/Visitors/ProductEditorVisitor.cpp Sources/Logic/Visitors/ProductIconVisitor.cpp Sources/Logic/Visitors/ProductSingleProductVisitor.cpp Sources/Logic/Store.cpp $(DISTDIR)/


